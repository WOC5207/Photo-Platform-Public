generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

// A gallery event = one photo album (a con, a shoot, etc.)
model Event {
  id            String    @id @default(cuid())
  slug          String    @unique
  titleEn       String
  titleZh       String
  descriptionEn String    @default("")
  descriptionZh String    @default("")
  location      String    @default("")
  dateStart     DateTime?
  dateEnd       DateTime?
  published     Boolean   @default(false)
  coverPhotoId  String?   @unique
  coverPhoto    Photo?    @relation("EventCover", fields: [coverPhotoId], references: [id], onDelete: SetNull)
  photos        Photo[]   @relation("EventPhotos")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Photo {
  id           String   @id @default(cuid())
  eventId      String
  event        Event    @relation("EventPhotos", fields: [eventId], references: [id], onDelete: Cascade)
  // Base name (no extension) of the stored files; sizes live at
  // <PHOTOS_DIR>/<eventId>/<filename>-{orig,full,med,thumb}.<ext>
  filename     String
  originalName String
  width        Int
  height       Int
  // One or more (credited person, subject) credits — most photos have one,
  // group shots have several.
  credits      PhotoCredit[]
  // EXIF read from the uploaded original at upload time (before it's
  // stripped for the displayed renditions). Null when the file had none.
  exifFocalLengthMm Float?
  exifAperture      Float?
  exifExposureTime  Float?
  exifIso           Int?
  exifTakenAt       DateTime?
  exifCameraModel   String?
  exifLensModel     String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  coverOf      Event?   @relation("EventCover")
  // Admin-picked for the homepage's per-event carousel. Independent of
  // coverPhotoId (which is exactly one photo per event, used for gallery
  // listing thumbnails) — any number of a published event's photos can be
  // marked here, and that's what populates its homepage carousel slides.
  homeHighlight Boolean @default(false)
}

// A single credited-person+subject credit on a photo. Shown identically on
// both the zh and en sites (these are names, not translatable content). A
// photo with multiple credited people gets one row per person.
model PhotoCredit {
  id            String       @id @default(cuid())
  photoId       String
  photo         Photo        @relation(fields: [photoId], references: [id], onDelete: Cascade)
  creditName    String
  subject       String       @default("")
  sortOrder     Int          @default(0)
  socialLinks   SocialLink[]
}

// A credited person's social-media profile link, shown as a button on the
// enlarged photo. A credit can link to several platforms.
model SocialLink {
  id        String      @id @default(cuid())
  creditId  String
  credit    PhotoCredit @relation(fields: [creditId], references: [id], onDelete: Cascade)
  // Free-text platform label typed by the admin (e.g. "Instagram", "小红书").
  platform  String
  url       String
  sortOrder Int         @default(0)
}

// A remembered social-media profile for a credited person, looked up by
// exact name text. Kept in sync automatically whenever a photo credit is
// saved with social links (see syncCreditProfiles in
// src/lib/photoCredits.ts), so the admin only has to type a person's links
// once — the photo-credit editors prefill new/matching rows from here.
// Independent of PhotoCredit/SocialLink, which remain the actual per-photo
// data that renders on the gallery; this table is never rendered directly,
// only consulted for autofill.
model CreditProfile {
  id          String                    @id @default(cuid())
  creditName  String                    @unique
  socialLinks CreditProfileSocialLink[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
}

model CreditProfileSocialLink {
  id              String        @id @default(cuid())
  creditProfileId String
  creditProfile   CreditProfile @relation(fields: [creditProfileId], references: [id], onDelete: Cascade)
  platform        String
  url             String
  sortOrder       Int           @default(0)
}

// A bookable photoshoot event with time slots (separate from gallery events)
model BookingEvent {
  id            String     @id @default(cuid())
  // Unguessable token used in the shareable public URL
  token         String     @unique
  titleEn       String
  titleZh       String
  descriptionEn String     @default("")
  descriptionZh String     @default("")
  location      String     @default("")
  date          DateTime
  open          Boolean    @default(true)
  // Whether the prize-draw tool is enabled for this event at all. Off by
  // default so existing/new events don't suddenly expose a "Prize draw"
  // link and public entry page until the admin opts in.
  lotteryEnabled Boolean   @default(false)
  slots         TimeSlot[]
  lotteryDraw   LotteryDraw?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model TimeSlot {
  id             String       @id @default(cuid())
  bookingEventId String
  bookingEvent   BookingEvent @relation(fields: [bookingEventId], references: [id], onDelete: Cascade)
  startTime      DateTime
  endTime        DateTime
  capacity       Int          @default(1)
  bookings       Booking[]
}

// Singleton row (id is always "site") holding admin-customizable site content.
model SiteSettings {
  id                  String   @id @default("site")
  siteTitleEn         String   @default("")
  siteTitleZh         String   @default("")
  // Homepage hero headline/subtitle. Empty = use the built-in default copy.
  homeTitleEn         String   @default("")
  homeTitleZh         String   @default("")
  homeSubtitleEn      String   @default("")
  homeSubtitleZh      String   @default("")
  // Empty = use the default dark theme color. Otherwise a CSS hex like "#0a0a0a".
  backgroundColor     String   @default("")
  // Empty = no background image. Otherwise a token; file lives at
  // <PHOTOS_DIR>/_site/<token>.webp, served via /api/site/<token>.webp.
  backgroundImage     String   @default("")
  // Logo shown in the admin header (links to the homepage). Empty = none.
  // Same token/storage scheme as backgroundImage.
  logo                String   @default("")
  // Vocabulary override for the "credited person" / "subject" concepts used
  // across the photo-credit editor, quick stats, and booking form (e.g. a
  // cosplay-photography operator might set "Cosplayer"/"Character"). Empty =
  // use the built-in generic default copy.
  creditTermEn        String   @default("")
  creditTermZh        String   @default("")
  subjectTermEn       String   @default("")
  subjectTermZh       String   @default("")
  // Site-wide feature switches. Off hides the feature's nav links and
  // homepage elements and blocks its public routes; admin management pages
  // for existing data stay reachable so nothing already collected is lost.
  bookingEnabled       Boolean  @default(true)
  lotteryEnabled       Boolean  @default(true)
  creditProfilesEnabled Boolean @default(true)
  announcementsEnabled Boolean  @default(true)
  // "Contact us" card shown behind a header/footer button on the public
  // site. Off hides the button entirely, site-wide. titleEn/Zh label the
  // card (empty = built-in default copy). The link and QR code are set
  // independently per language — e.g. a WeChat QR for the Chinese site and
  // a WhatsApp link for the English one — so each is empty = no contact
  // method for that language (the button just doesn't render on that
  // locale, even if the other language has one configured). QR image
  // fields use the same token/storage scheme as backgroundImage/logo.
  contactEnabled       Boolean  @default(false)
  contactTitleEn       String   @default("")
  contactTitleZh       String   @default("")
  contactUrlEn         String   @default("")
  contactUrlZh         String   @default("")
  contactQrImageEn     String   @default("")
  contactQrImageZh     String   @default("")
  // Flips to true once the first-run setup wizard (src/app/[locale]/admin/setup)
  // finishes. While false, every /admin/(protected) route redirects there.
  setupCompleted       Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

// Admin-managed links to the photographer's other sites/profiles, shown in
// the homepage sidebar below the quick-stats card.
model PersonalLink {
  id        String   @id @default(cuid())
  labelEn   String
  labelZh   String
  url       String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Admin-configured options for the booking form's contact-method dropdown
// (e.g. WeChat, QQ, Email, Instagram...). Bookings store the chosen label as
// plain text (see Booking.contactMethod), so editing/deleting an option here
// never changes past bookings.
model ContactMethod {
  id        String   @id @default(cuid())
  labelEn   String
  labelZh   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Short admin-authored notices shown in the homepage panel's Announcements
// tab (e.g. "Booking for March is now open"). No draft state — like
// PersonalLink/ContactMethod, an announcement is live as soon as it's saved.
model Announcement {
  id        String   @id @default(cuid())
  titleEn   String
  titleZh   String
  bodyEn    String   @default("")
  bodyZh    String   @default("")
  // Optional accompanying image, one per announcement (not split by
  // language — same token/storage scheme as backgroundImage/logo, but
  // keyed per-row here instead of the SiteSettings singleton).
  image     String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

model Booking {
  id            String   @id @default(cuid())
  timeSlotId    String
  timeSlot      TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)
  // Visitor's name/handle (shown to the photographer)
  name          String
  // Subject of the shoot (character, role, theme...), optional.
  subject       String   @default("")
  // Chosen contact-method label (e.g. "WeChat") and the value for it (e.g.
  // the visitor's WeChat ID). Both stored as plain text, not a foreign key,
  // so the booking stays intact even if the admin later edits or removes
  // that ContactMethod option.
  contactMethod String   @default("")
  contactValue  String   @default("")
  notes         String   @default("")
  // "confirmed" | "cancelled" (SQLite has no enums)
  status        String   @default("confirmed")
  // Private token for the visitor's self-cancel link
  cancelToken   String   @unique
  createdAt     DateTime @default(now())
  lotteryEntry  LotteryEntry?
}

// A prize draw ("抽奖") tied to one booking event. Entrants either come from
// the admin hand-picking confirmed bookings, or from visitors filling in the
// shareable public entry link (token). Either way each becomes a
// LotteryEntry with its own display token, so the wheel can show tokens
// instead of names until a winner is revealed.
model LotteryDraw {
  id             String         @id @default(cuid())
  bookingEventId String         @unique
  bookingEvent   BookingEvent   @relation(fields: [bookingEventId], references: [id], onDelete: Cascade)
  // Unguessable token used in the shareable public entry-link URL
  token          String         @unique
  // Whether the public entry link currently accepts new self-entries. Toggled
  // off once the admin wants to lock the pool. Spinning itself is always
  // available while the event's lottery is enabled — there is no separate
  // per-draw spin switch.
  open           Boolean        @default(true)
  entries        LotteryEntry[]
  prizes         LotteryPrize[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// One entrant in a draw: either wrapping a confirmed booking the admin
// selected, or a standalone self-entry a visitor submitted through the
// public link (bookingId null). name/subject/contactMethod/
// contactValue are always populated on the entry itself (copied from the
// booking at add-time, or typed in directly), so display never has to join
// out to Booking. Once an entry wins a prize, wonPrizeId/wonAt are set and
// it drops out of the pool for later spins.
model LotteryEntry {
  id            String        @id @default(cuid())
  drawId        String
  draw          LotteryDraw   @relation(fields: [drawId], references: [id], onDelete: Cascade)
  bookingId     String?       @unique
  booking       Booking?      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  name          String
  subject       String        @default("")
  contactMethod String        @default("")
  contactValue  String        @default("")
  token         String
  wonPrizeId    String?
  wonPrize      LotteryPrize? @relation(fields: [wonPrizeId], references: [id], onDelete: SetNull)
  wonAt         DateTime?
  createdAt     DateTime      @default(now())

  @@unique([drawId, token])
}

// A prize option on the wheel. Remaining stock is derived as quantity minus
// the number of entries linked via wonPrizeId. `weight` is this prize's
// relative chance on the wheel compared to the other in-stock prizes (not a
// percentage — e.g. weight 10 vs weight 1 means ~10x as likely), so slice
// size and odds shrink automatically as prizes with higher weight run out.
model LotteryPrize {
  id        String         @id @default(cuid())
  drawId    String
  draw      LotteryDraw    @relation(fields: [drawId], references: [id], onDelete: Cascade)
  name      String
  quantity  Int            @default(1)
  weight    Int            @default(1)
  sortOrder Int            @default(0)
  winners   LotteryEntry[]
  createdAt DateTime       @default(now())
}
