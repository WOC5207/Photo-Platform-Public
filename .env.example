# ============================================================
# Photo Platform — environment configuration
# Copy this file to `.env` and fill in every value.
# ============================================================

# --- Database ---------------------------------------------------------
# SQLite file path. Inside Docker this must stay as below (it points at the
# mounted /data/db volume). connection_limit=1 serializes writes, which is
# what makes concurrent booking attempts safe on SQLite.
DATABASE_URL="file:/data/db/app.db?connection_limit=1"

# --- Storage ----------------------------------------------------------
# Where photo originals and generated sizes are stored. Inside Docker this
# must stay as below (the mounted /data/photos volume).
PHOTOS_DIR="/data/photos"

# --- Admin account (seeded into the database on first login) ----------
ADMIN_USERNAME="admin"
# Choose a long, unique password. It is stored only as a bcrypt hash.
ADMIN_PASSWORD="change-me-to-a-long-password"

# --- Sessions ---------------------------------------------------------
# At least 32 random characters. Generate one with:
#   openssl rand -base64 32
SESSION_SECRET="change-me-32-characters-minimum-random-string"

# --- Public URL -------------------------------------------------------
# The public HTTPS address of the site (your DSM reverse-proxy hostname).
# Used to build shareable booking links and visitor cancel links.
APP_BASE_URL="https://photos.example.com"

# --- Privacy ----------------------------------------------------------
# Displayed images ALWAYS have all EXIF (including GPS) stripped.
# Set to "true" to also scrub EXIF from the stored originals on upload.
STRIP_ORIGINAL_EXIF="false"

# --- Uploads ----------------------------------------------------------
# Maximum size of a single uploaded photo, in megabytes.
UPLOAD_MAX_MB="100"
